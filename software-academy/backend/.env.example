# Скопируй этот файл в .env:  cp .env.example .env
# Файл .env в git НЕ попадает (см. корневой .gitignore).

# --- База данных ---
# Для локального запуска (БД на твоей машине / в Docker с проброшенным портом):
DATABASE_URL=postgresql+psycopg://academy:academy@localhost:5432/academy
# Внутри docker compose адрес переопределяется на host "db" (см. docker-compose.yml).

# --- JWT (понадобится на Шаге 4) ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
